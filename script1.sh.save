#!/bin/bash
# Script 1: System Identity Report
# Author: [Sanskar Prashad Tiwari] | Reg No: [24BCG10068]
# Course: Open Source Software
# Description: Displays system information like a welcome screen


STUDENT_NAME="Sanskar Prashad Tiwari"
SOFTWARE_CHOICE="PYTHON"

#System info using command substitution 
KERNEL=$(uname -r)
USER_NAME=$(whoami)
UPTIME=$(uptime -p)
DATE=$(date '+%d %B %Y, %H:%M')
DISTRO=$(grep PRETTY_NAME /etc/os-release | cut -d= -f2 | tr -d '"')
HOME_DIR=$(echo $HOME)

echo " Open Source Audit — $STUDENT_NAME"
echo "Software Audited : $SOFTWARE_CHOICE"
echo "Kernel Version   : $KERNEL"
echo "Distribution     : $DISTRO"
echo "Logged in as     : $USER_NAME"
echo "Home Directory   : $HOME_DIR"
echo "System Uptime    : $UPTIME"
echo "Date & Time      : $DATE"
echo "Python is released under the PSF License."
echo "It grants all four freedoms of free software."
